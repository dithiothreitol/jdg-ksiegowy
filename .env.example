# === Dane sprzedawcy (WYMAGANE) ===
SELLER_NAME=Twoja Firma Sp. z o.o.
SELLER_NIP=0000000000
SELLER_ADDRESS=ul. Przykladowa 1, 00-001 Warszawa
SELLER_BANK_ACCOUNT=00 0000 0000 0000 0000 0000 0000
SELLER_BANK_NAME=Nazwa Banku
SELLER_EMAIL=kontakt@firma.pl
SELLER_TAX_FORM=ryczalt                # ryczalt | zasady_ogolne | liniowy
SELLER_RYCZALT_RATE=12                 # stawka ryczaltu (%)
SELLER_VAT_RATE=23                     # stawka VAT (%)
SELLER_VAT_EXEMPT=false                # true jesli zwolnienie podmiotowe z VAT

# Dane osobowe (WYMAGANE dla JPK_V7M)
SELLER_FIRST_NAME=Jan
SELLER_LAST_NAME=Kowalski
SELLER_BIRTH_DATE=1990-01-01           # format: YYYY-MM-DD
SELLER_TAX_OFFICE_CODE=1471            # kod urzedu skarbowego

# === KSeF ===
KSEF_ENV=test                          # test | demo | prod
KSEF_NIP=                              # domyslnie = SELLER_NIP
KSEF_TOKEN=your-ksef-authorization-token

# === Bramka MF (JPK_V7M / JPK_EWP) — autoryzacja danymi ===
MF_ENV=test                            # test | prod
MF_PESEL=                              # PESEL podatnika (osoba fizyczna prowadzaca JDG)
MF_PRIOR_INCOME=0                      # kwota przychodu z PIT za rok N-2 (dla 2026 -> PIT-37/28/36 za 2024)
                                       # PIT-37 poz. 50/83, PIT-28 poz. 20/22/24/62/73, PIT-36 poz. 67-75/131
                                       # Brak zeznania -> 0. Nie sumowac z roznych zeznan.
MF_CERT_PATH=                          # lokalny plik PEM/DER (override auto-download)
MF_CERT_URL=                           # URL PEM z komunikatu MF (patrz:
                                       # https://www.podatki.gov.pl/komunikaty-techniczne/)
                                       # jesli puste + brak MF_CERT_PATH -> wysylka nie zadziala
MF_CERT_TTL_DAYS=30                    # co ile dni sprawdzac rotacje klucza

# === OpenClaw — model AI (hybrid: Ollama + Claude fallback) ===
#
# PRIMARY: Ollama lokalny (darmowy, prywatny, bez ryzyka blokady)
OPENCLAW_PROVIDER=ollama
OPENCLAW_MODEL=qwen3.5:9b             # vision + polski + JSON, 6.6 GB VRAM
OLLAMA_BASE_URL=http://localhost:11434
#
# FALLBACK: Claude API pay-as-you-go (dla zlozonych pytan podatkowych)
# UWAGA: NIE uzywaj subskrypcji Claude Pro/Max — Anthropic zablokowal
#         OpenClaw z subskrypcji od 4.04.2026. Tylko API key.
ANTHROPIC_API_KEY=                     # sk-ant-... (opcjonalny, pay-as-you-go)
#
# Alternatywne modele Ollama do ksiegowosci:
#   qwen3-vl:8b       — OCR faktur ze zdjec (6.1 GB)
#   gemma4:26b         — structured output (18 GB)
#   bielik:11b         — dedykowany polski model (~8 GB)
#
# === OpenClaw — kanaly komunikacji ===
# Konfigurowane przez: openclaw channels login whatsapp|telegram
# Nie wymagaja env vars — skanuj QR / podaj token bota
