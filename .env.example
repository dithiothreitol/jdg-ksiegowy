# === Dane sprzedawcy (WYMAGANE) ===
SELLER_NAME=Twoja Firma Sp. z o.o.
SELLER_NIP=0000000000
SELLER_ADDRESS=ul. Przykladowa 1, 00-001 Warszawa
SELLER_BANK_ACCOUNT=00 0000 0000 0000 0000 0000 0000
SELLER_BANK_NAME=Nazwa Banku
SELLER_EMAIL=kontakt@firma.pl
SELLER_TAX_FORM=ryczalt                # ryczalt | zasady_ogolne | liniowy
SELLER_RYCZALT_RATE=12                 # stawka ryczaltu (%)
SELLER_VAT_RATE=23                     # stawka VAT (%)
SELLER_VAT_EXEMPT=false                # true jesli zwolnienie podmiotowe z VAT

# Dane osobowe (WYMAGANE dla JPK_V7M)
SELLER_FIRST_NAME=Jan
SELLER_LAST_NAME=Kowalski
SELLER_BIRTH_DATE=1990-01-01           # format: YYYY-MM-DD
SELLER_TAX_OFFICE_CODE=1471            # kod urzedu skarbowego

# === ZUS — skladki spoleczne ===
# SELLER_BUSINESS_START_DATE: data rozpoczecia lub wznowienia JDG (YYYY-MM-DD).
#   Auto-wyliczenie okresu ulgi na start (6 mies) i preferencyjnego (24 mies).
SELLER_BUSINESS_START_DATE=2024-01-01
# SELLER_ZUS_SOCIAL_MODE: auto | start_relief | small_zus | employment | full
#   - auto      -> wyliczenie na podstawie daty i employment flag
#   - start_relief -> ulga na start (6 mies, 0 PLN spolecznych)
#   - small_zus -> preferencyjne 30% min. wyn. (24 mies po uldze)
#   - employment -> zbieg z UoP >= min. wyn. (brak spolecznych z JDG)
#   - full      -> pelne skladki (60% prognozowanego przecietnego)
SELLER_ZUS_SOCIAL_MODE=auto
# SELLER_EMPLOYMENT_GROSS_ABOVE_MIN: masz rownolegle UoP z brutto >= min. wyn.?
#   2026 min. wyn. = 4806 PLN. true -> mode=employment niezaleznie od daty.
SELLER_EMPLOYMENT_GROSS_ABOVE_MIN=false
# SELLER_ZUS_VOLUNTARY_SICKNESS: dobrowolna skladka chorobowa (daje zasilek L4)
SELLER_ZUS_VOLUNTARY_SICKNESS=false

# === KSeF ===
KSEF_ENV=test                          # test | demo | prod
KSEF_NIP=                              # domyslnie = SELLER_NIP
KSEF_TOKEN=your-ksef-authorization-token

# === Bramka MF (JPK_V7M / JPK_EWP) — autoryzacja danymi ===
MF_ENV=test                            # test | prod
MF_PESEL=                              # PESEL podatnika (osoba fizyczna prowadzaca JDG)
MF_PRIOR_INCOME=0                      # kwota przychodu z PIT za rok N-2 (dla 2026 -> PIT-37/28/36 za 2024)
                                       # PIT-37 poz. 50/83, PIT-28 poz. 20/22/24/62/73, PIT-36 poz. 67-75/131
                                       # Brak zeznania -> 0. Nie sumowac z roznych zeznan.
MF_CERT_PATH=                          # lokalny plik PEM/DER (override auto-download)
MF_CERT_URL=                           # URL PEM z komunikatu MF (patrz:
                                       # https://www.podatki.gov.pl/komunikaty-techniczne/)
                                       # jesli puste + brak MF_CERT_PATH -> wysylka nie zadziala
MF_CERT_TTL_DAYS=30                    # co ile dni sprawdzac rotacje klucza

# === SMTP (wysylka faktur mailem — skill invoice-send) ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587                          # 465 dla SSL, 587 dla STARTTLS
SMTP_USERNAME=
SMTP_PASSWORD=                         # Gmail: App Password (nie glowne haslo)
SMTP_FROM=                             # pusty -> uzywa SMTP_USERNAME
SMTP_USE_SSL=false                     # true dla portu 465

# === LibreOffice (konwersja DOCX -> PDF przed wysylka mailem) ===
LIBREOFFICE_BIN=                       # pusty = uzywa `soffice`/`libreoffice` z PATH

# === OpenClaw — model AI (hybrid: Ollama + Claude fallback) ===
#
# PRIMARY: Ollama lokalny (darmowy, prywatny, bez ryzyka blokady)
OPENCLAW_PROVIDER=ollama
OPENCLAW_MODEL=qwen3.5:9b             # baseline: vision + polski + JSON, 6.6 GB VRAM
                                       # desktop >=32 GB RAM: qwen3.5:35b (MoE 35B-A3B, ~24 GB) — rekomendowane
                                       # patrz INSTALL.md sekcja 3
OLLAMA_BASE_URL=http://localhost:11434
#
# FALLBACK: Claude API pay-as-you-go (dla zlozonych pytan podatkowych)
# UWAGA: NIE uzywaj subskrypcji Claude Pro/Max — Anthropic zablokowal
#         OpenClaw z subskrypcji od 4.04.2026. Tylko API key.
ANTHROPIC_API_KEY=                     # sk-ant-... (opcjonalny, pay-as-you-go)
#
# Alternatywne modele Ollama do ksiegowosci:
#   qwen3.5:35b        — rekomendowany na desktopie (MoE 35B-A3B, ~24 GB RAM)
#   qwen3.5:27b        — srodek (dense, ~17 GB)
#   qwen3.5:9b         — baseline (default, ~6.6 GB)
#   bielik:11b         — dedykowany polski model (~8 GB)

# === OCR faktur zakupu ===
OCR_PROVIDER=auto                      # auto | ollama | claude
OCR_OLLAMA_URL=http://localhost:11434
OCR_OLLAMA_MODEL=pixtral:12b           # domyslnie Pixtral (lepszy niz qwen3-vl dla dokumentow)
OCR_OLLAMA_TIMEOUT=120                 # sekund (CPU inference moze byc wolny)
OCR_CLAUDE_MODEL=claude-haiku-4-5-20251001
OCR_CLAUDE_MAX_TOKENS=1024
# ANTHROPIC_API_KEY powyzej (sekcja OpenClaw) — ten sam klucz uzywany tez dla OCR fallbacku
#
# === OpenClaw — kanaly komunikacji ===
# Konfigurowane przez: openclaw channels login whatsapp|telegram
# Nie wymagaja env vars — skanuj QR / podaj token bota
